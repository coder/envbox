module github.com/coder/envbox

go 1.25.9

// There are a few minor changes we make to Tailscale that we're slowly upstreaming. Compare here:
// https://github.com/tailscale/tailscale/compare/main...coder:tailscale:main
replace tailscale.com => github.com/coder/tailscale v1.1.1-0.20260409064601-e956a950740b

replace github.com/gliderlabs/ssh => github.com/coder/ssh v0.0.0-20231128192721-70855dedb788

replace github.com/tailscale/wireguard-go => github.com/coder/wireguard-go v0.0.0-20260113101225-9b7a56210e49

replace gvisor.dev => github.com/coder/gvisor v0.0.0-20260313164934-7a658db7b714

// docker/cli v29 reaches into the new moby/moby/client v0 module. We don't depend on
// docker/cli for runtime use; ory/dockertest only uses cli/compose/loader and opts.
// Both the legacy moby/moby and standalone moby/moby/client modules ship the same
// "github.com/moby/moby/client" package, which Go cannot disambiguate when the parent
// module is +incompatible (lacks its own go.mod). Pin docker/cli to v27.4.1 (the
// version dockertest itself requires) so the loader does not import moby/moby/client.
replace github.com/docker/cli => github.com/docker/cli v27.4.1+incompatible

